// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite doesn't support enums, so we'll use strings with constraints

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("USER") // USER, VET, CLINIC, PHARMACY, ADMIN
  name         String
  phone        String?
  city         String?
  lat          Float?
  lng          Float?
  avatar       String?
  isActive     Boolean  @default(true)
  emailVerified Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  vet          Vet?
  clinic       Clinic?
  pharmacy     Pharmacy?
  consultations Consultation[]
  messages     Message[]
  wallet       Wallet?
  notifications Notification[]
  partnerRequests PartnerRequest[]
  transactions Transaction[]
  orders       Order[]

  @@map("users")
}

model Vet {
  id             String   @id @default(cuid())
  userId         String   @unique
  slug           String   @unique
  specialties    String?  // JSON string of specialties
  priceOnline    Float?
  pricePhone     Float?
  priceHome      Float?
  hasHomeVisit   Boolean  @default(false)
  hasOnline      Boolean  @default(true)
  hasPhone       Boolean  @default(true)
  bio            String?
  experience     Int?     // years
  rating         Float    @default(0)
  reviewCount    Int      @default(0)
  city           String
  address        String?
  lat            Float?
  lng            Float?
  isVerified     Boolean  @default(false)
  isActive       Boolean  @default(true)
  workingHours   String?  // JSON object for working hours
  gallery        String?  // JSON string of image URLs
  certificates   String?  // JSON string of certificate URLs
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  consultations Consultation[]
  reviews       Review[]

  @@map("vets")
}

model Clinic {
  id           String   @id @default(cuid())
  userId       String   @unique
  slug         String   @unique
  name         String
  bannerUrl    String?
  services     String?  // JSON string of services
  description  String?
  city         String
  address      String?
  lat          Float?
  lng          Float?
  phone        String?
  email        String?
  website      String?
  rating       Float    @default(0)
  reviewCount  Int      @default(0)
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)
  workingHours String?  // JSON object for working hours
  gallery      String?  // JSON string of image URLs
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@map("clinics")
}

model Pharmacy {
  id          String   @id @default(cuid())
  userId      String   @unique
  slug        String   @unique
  name        String
  city        String
  address     String?
  lat         Float?
  lng         Float?
  phone       String?
  email       String?
  website     String?
  is24h       Boolean  @default(false)
  hasDelivery Boolean  @default(false)
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  isVerified  Boolean  @default(false)
  isActive    Boolean  @default(true)
  gallery     String?  // JSON string of image URLs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews Review[]
  orders  Order[]

  @@map("pharmacies")
}

model Consultation {
  id          String            @id @default(cuid())
  userId      String
  vetId       String
  status      String            @default("PENDING") // PENDING, APPROVED, OPEN, CLOSED, CANCELLED
  serviceType String            // "online", "phone", "home"
  price       Float
  formData    String            // JSON object with consultation form data
  description String?
  petType     String?
  petBreed    String?
  petAge      String?
  urgency     String?           @default("normal")
  scheduledAt DateTime?
  startedAt   DateTime?
  endedAt     DateTime?
  rating      Float?
  review      String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vet      Vet       @relation(fields: [vetId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("consultations")
}

model Message {
  id             String      @id @default(cuid())
  consultationId String
  senderId       String
  type           String      @default("TEXT") // TEXT, IMAGE, FILE, PRESCRIPTION
  content        String
  fileUrl        String?
  fileName       String?
  fileSize       Int?
  isRead         Boolean     @default(false)
  createdAt      DateTime    @default(now())

  // Relations
  consultation Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  walletId    String
  amount      Float
  type        String          // DEPOSIT, WITHDRAWAL, PAYMENT, REFUND, COMMISSION
  reference   String?         // consultation ID, payment gateway ref, etc.
  description String?
  metadata    String?         // JSON object for additional data
  createdAt   DateTime        @default(now())

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String    // "consultation", "chat", "payment", etc.
  title     String
  body      String
  data      String?   // JSON object for additional data
  readAt    DateTime?
  createdAt DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Review {
  id         String   @id @default(cuid())
  userId     String
  vetId      String?
  clinicId   String?
  pharmacyId String?
  rating     Float
  comment    String?
  createdAt  DateTime @default(now())

  // Relations
  vet      Vet?      @relation(fields: [vetId], references: [id], onDelete: Cascade)
  clinic   Clinic?   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  pharmacy Pharmacy? @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model PartnerRequest {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "vet", "clinic", "pharmacy"
  name        String
  email       String
  phone       String
  city        String
  description String?
  documents   String? // JSON string of document URLs
  status      String   @default("pending") // "pending", "approved", "rejected"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("partner_requests")
}

model Order {
  id               String   @id @default(cuid())
  trackingCode     String   @unique
  userId           String
  pharmacyId       String
  status           String   @default("pending") // "pending", "confirmed", "preparing", "ready", "shipped", "delivered", "cancelled", "returned"
  totalAmount      Float
  deliveryAddress  String?
  deliveryPhone    String?
  notes           String?
  confirmedAt     DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  pharmacy Pharmacy     @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  items    OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  medicineId String
  quantity  Int
  price     Float
  createdAt DateTime @default(now())

  // Relations
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  medicine Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Medicine {
  id          String @id @default(cuid())
  name        String
  description String?
  price       Float
  image       String?
  category    String?
  brand       String?
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  orderItems  OrderItem[]

  @@map("medicines")
}
